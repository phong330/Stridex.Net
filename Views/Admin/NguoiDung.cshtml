@model List<NguoiDung>
@{
    ViewData["Title"] = "Người dùng";
}
<section class="container py-5">
    <h1 class="fw-bold mb-4">Danh sách người dùng</h1>
    <div class="card border-0 shadow-sm table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>ID</th><th>Họ tên</th><th>Email</th><th>Vai trò</th></tr></thead>
            <tbody>
            @foreach (var nd in Model)
            {
                <tr>
                    <td>@nd.Id</td>
                    <td>@nd.HoTen</td>
                    <td>@nd.Email</td>
                    <td><span class="badge text-bg-dark">@nd.VaiTro</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
