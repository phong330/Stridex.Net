@model List<SanPham>
@{
    ViewData["Title"] = "Trang chủ";
}
<section class="hero">
    <div class="container py-5">
        <div class="row align-items-center gy-4">
            <div class="col-lg-7">
                <p class="badge rounded-pill bg-light text-dark">STRIDEX SPORT STORE</p>
                <h1 class="display-5 fw-bold">Nâng cấp phong cách thể thao của bạn</h1>
                <p class="lead">Giày, áo, quần, bóng, vợt và phụ kiện thể thao. Dữ liệu lấy trực tiếp từ SQL Server.</p>
                <a class="btn btn-light btn-lg" asp-controller="SanPham" asp-action="Index">Xem sản phẩm</a>
            </div>
            <div class="col-lg-5">
                <div class="hero-card">
                    <div class="circle"></div>
                    <h3>Final C# Project</h3>
                    <p>ASP.NET Core MVC • SQL Server • Giỏ hàng • Đơn hàng • Admin CRUD</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Sản phẩm nổi bật</h2>
        <a asp-controller="SanPham" asp-action="Index" class="btn btn-outline-dark">Xem tất cả</a>
    </div>
    <div class="row g-4">
        @foreach (var sp in Model)
        {
            <div class="col-md-6 col-lg-3">
                <partial name="_ProductCard" model="sp" />
            </div>
        }
    </div>
</section>
