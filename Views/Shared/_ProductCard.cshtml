@model SanPham
<div class="card product-card h-100">
    <div class="ratio ratio-4x3 bg-light">
        <img src="@(string.IsNullOrWhiteSpace(Model.Hinh) ? "https://placehold.co/600x450?text=STRIDEX" : Model.Hinh)" class="card-img-top" alt="@Model.Ten" />
    </div>
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-2">
            <span class="badge text-bg-dark">@Model.Loai</span>
            @if (Model.NoiBat) { <span class="badge text-bg-warning">Hot</span> }
        </div>
        <h5 class="card-title mt-2">@Model.Ten</h5>
        <p class="price mb-3">@Model.Gia.ToString("N0") đ</p>
        <div class="mt-auto d-flex gap-2">
            <a asp-controller="SanPham" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark flex-fill">Chi tiết</a>
            <a asp-controller="GioHang" asp-action="Them" asp-route-id="@Model.Id" class="btn btn-dark flex-fill">Thêm</a>
        </div>
    </div>
</div>
