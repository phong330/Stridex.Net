@using StridexFinal_CSharp.Extensions
@using StridexFinal_CSharp.Models
@{
    var hoTen = Context.Session.GetString("HoTen");
    var vaiTro = Context.Session.GetString("VaiTro");
    var gioHang = Context.Session.GetObject<List<GioHangItem>>("GioHang") ?? new List<GioHangItem>();
    var soLuongGio = gioHang.Sum(x => x.SoLuong);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - STRIDEX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header class="sticky-top">
    <nav class="navbar navbar-expand-lg navbar-dark nav-stridex">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">STRIDEX<span>.VN</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="SanPham" asp-action="Index">Sản phẩm</a></li>
                    @if (string.Equals(vaiTro, "Admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Quản trị</a></li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-lg-2">
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm" asp-controller="GioHang" asp-action="Index">Giỏ hàng (@soLuongGio)</a>
                    </li>
                    @if (!string.IsNullOrWhiteSpace(hoTen))
                    {
                        <li class="nav-item"><span class="text-white small">Xin chào, @hoTen</span></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="DonHang" asp-action="LichSu">Đơn hàng</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="TaiKhoan" asp-action="DangXuat">Đăng xuất</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="TaiKhoan" asp-action="DangNhap">Đăng nhập</a></li>
                        <li class="nav-item"><a class="btn btn-light btn-sm" asp-controller="TaiKhoan" asp-action="DangKy">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <div class="container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>
    @RenderBody()
</main>

<footer class="py-4 mt-5 footer-stridex">
    <div class="container d-flex flex-wrap justify-content-between gap-3">
        <div>
            <strong>STRIDEX.VN</strong><br />
            <span>Website bán hàng thể thao xây dựng bằng C# ASP.NET Core MVC.</span>
        </div>
        <div>© @DateTime.Now.Year - Final Project</div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
