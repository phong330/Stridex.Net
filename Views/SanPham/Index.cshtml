@model List<SanPham>
@{
    ViewData["Title"] = "Sản phẩm";
    var loaiList = ViewBag.Loai as List<string> ?? new List<string>();
}
<section class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
        <div>
            <h1 class="fw-bold">Danh sách sản phẩm</h1>
            <p class="text-muted mb-0">Tìm kiếm, lọc và sắp xếp sản phẩm thể thao STRIDEX.</p>
        </div>
    </div>

    <form class="filter-box row g-2 mb-4" method="get">
        <div class="col-md-5">
            <input name="tuKhoa" value="@ViewBag.TuKhoa" class="form-control" placeholder="Tìm theo tên sản phẩm..." />
        </div>
        <div class="col-md-3">
            <select name="loai" class="form-select">
                <option value="">Tất cả loại</option>
                @foreach (var loai in loaiList)
                {
                    <option value="@loai" selected="@(ViewBag.LoaiChon == loai)">@loai</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="sort" class="form-select">
                <option value="">Mặc định</option>
                <option value="gia-tang" selected="@(ViewBag.Sort == "gia-tang")">Giá tăng</option>
                <option value="gia-giam" selected="@(ViewBag.Sort == "gia-giam")">Giá giảm</option>
                <option value="ten" selected="@(ViewBag.Sort == "ten")">Tên A-Z</option>
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-dark">Lọc</button>
        </div>
    </form>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12"><div class="alert alert-warning">Không tìm thấy sản phẩm phù hợp.</div></div>
        }
        @foreach (var sp in Model)
        {
            <div class="col-md-6 col-lg-3"><partial name="_ProductCard" model="sp" /></div>
        }
    </div>
</section>
