@model DonHang
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}
<section class="container py-5">
    <div class="d-flex flex-wrap justify-content-between gap-3 mb-4">
        <div>
            <h1 class="fw-bold">Đơn hàng @Model.MaDonHang</h1>
            <p class="text-muted mb-0">Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <span class="badge text-bg-dark align-self-start fs-6">@Model.TrangThai</span>
    </div>
    <div class="card border-0 shadow-sm table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>Số lượng</th><th>Thành tiền</th></tr></thead>
            <tbody>
            @foreach (var ct in Model.ChiTiet)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img class="thumb" src="@(string.IsNullOrWhiteSpace(ct.Hinh) ? "https://placehold.co/80" : ct.Hinh)" />
                            <strong>@ct.TenSanPham</strong>
                        </div>
                    </td>
                    <td>@ct.DonGia.ToString("N0") đ</td>
                    <td>@ct.SoLuong</td>
                    <td><strong>@ct.ThanhTien.ToString("N0") đ</strong></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="text-end fs-4 fw-bold mt-3">Tổng tiền: @Model.TongTien.ToString("N0") đ</div>
</section>
